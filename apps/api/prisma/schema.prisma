// Atlas Birdie — Prisma Schema
// Phase 0: schema base com datasource configurado.
// Modelos de domínio serão adicionados na Phase 1.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
